# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local config overrides (user config lives in platformdirs config dir)
config.local.toml

# Local-only test screenshots (not for the public repo)
assets/fixtures/*.png

# Flatpak build artifacts (the manifest + python-deps are tracked; build output isn't)
packaging/flatpak/_build/
packaging/flatpak/.flatpak-builder/
packaging/flatpak/flatpak-pip-generator
packaging/flatpak/_repo/
packaging/flatpak/*.flatpak
